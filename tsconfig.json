{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "es2020",
    "module": "preserve",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "./dist"
  ],
}
